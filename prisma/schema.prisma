generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  image         String?
  role          Role       @default(PENDING)
  firstNameEn   String?
  lastNameEn    String?
  firstNameZh   String?
  lastNameZh    String?
  contactEmail  String?
  phone         String?
  emailVerified DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  schedules     Schedule[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Schedule {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  startTime   String
  endTime     String
  telescope   String?
  userId      String
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  location    String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WeatherReading {
  id                           String   @id @default(cuid())
  scriptTimestamp              DateTime @default(now())
  consoleTime                  DateTime @unique
  stationDate                  String
  stationTime                  String

  // Sensor readings
  outsideTempC                 Float?
  insideTempC                  Float?
  outsideHumidityPercent       Float?
  insideHumidityPercent        Float?
  barometerHpa                 Float?
  windSpeedMs                  Float?
  windDirectionDeg             Float?
  windDirectionText            String?
  windGustMs                   Float?
  windGustDirDeg               Float?
  rainRateMmHr                 Float?
  dailyRainMm                  Float?
  stormRainMm                  Float?
  monthlyRainMm                Float?
  yearlyRainMm                 Float?
  lastHourRainMm               Float?
  last15MinRainMm              Float?
  last24hrRainMm               Float?
  dewpointC                    Float?
  heatIndexC                   Float?
  windChillC                   Float?
  thswIndexC                   Float?
  consoleBatteryV              Float?
  avgWind2minMs                Float?

  // Station hi/lo
  outTempDayHighC              Float?
  outTempDayLowC               Float?
  inTempDayHighC               Float?
  inTempDayLowC                Float?
  baroDayHighHpa               Float?
  baroDayLowHpa                Float?
  windDayHighMs                Float?
  windMonthHighMs              Float?
  windYearHighMs               Float?
  windChillDayLowC             Float?
  heatIndexDayHighC            Float?
  rainRateDayHighMmHr          Float?
  rainRateHourHighMmHr         Float?

  // Astronomical
  sunrise                      String?
  sunset                       String?

  // Daemon-calculated rolling stats
  avgWind1MinMs                Float?
  avgWind10MinMs               Float?
  hiWind10MinMs                Float?

  // Meteoblue forecast (matched by hour)
  cloudCoverHigh               Float?
  cloudCoverMid                Float?
  cloudCoverLow                Float?
  seeing                       Float?
  moonrise                     String?
  moonset                      String?
  moonPhase                    String?

  @@index([consoleTime])
  @@index([stationDate, consoleTime])
}

enum Role {
  PENDING
  MEMBER
  OPERATOR
  MANAGER
  ADMIN
}
